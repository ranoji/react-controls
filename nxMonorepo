## 🚏 API Gateway (apps/api/src/main.js)

```js
const express = require('express');
const bodyParser = require('body-parser');
require('dotenv').config();

const { connectMongo } = require('../../libs/core/src/mongo');
const authRoutes = require('../../libs/auth/src/authRoutes');
const userRoutes = require('../../libs/users/src/userRoutes');

const app = express();
app.use(bodyParser.json());

// Routes
app.use('/auth', authRoutes);
app.use('/users', userRoutes);

const PORT = process.env.PORT || 4000;
(async () => {
  await connectMongo(process.env.MONGO_URI, process.env.DB_NAME);
  app.listen(PORT, () => console.log(`🚀 API running on http://localhost:${PORT}`));
})();
```

