## 15) Orders Module – MongoDB + JWT Guards (JS)

This adds a full **Orders** module with:

* Mongoose models
* Authenticated endpoints
* Ownership/role checks (`user` vs `admin`)
* Server-side price snapshot & total calculation

### 15.1 Folder layout

```
libs/orders/
  order.model.js
  order.repo.js (optional abstraction)
  order.routes.js
```

### 15.2 `libs/orders/order.model.js`

```js
const mongoose = require('mongoose');

const OrderItemSchema = new mongoose.Schema({
  productId: { type: mongoose.Schema.Types.ObjectId, ref: 'Product', required: true },
  name: { type: String, required: true },        // snapshot
  price: { type: Number, required: true },       // snapshot (cents or float)
  qty: { type: Number, required: true, min: 1 }
}, { _id: false });

const OrderSchema = new mongoose.Schema({
  userId: { type: mongoose.Schema.Types.ObjectId, ref: 'User', required: true, index: true },
  items: { type: [OrderItemSchema], required: true },
  subtotal: { type: Number, required: true },
  status: { type: String, enum: ['pending', 'paid', 'cancelled'], default: 'pending', index: true },
}, { timestamps: true });

module.exports = mongoose.model('Order', OrderSchema);
```

### 15.3 `libs/orders/order.routes.js`

```js
const express = require('express');
const mongoose = require('mongoose');
const { z } = require('zod');
const { jwtMiddleware } = require('../auth/jwt-middleware');
const { roleGuard } = require('../auth/role-guard');
const Product = require('../products/product.model');
const Order = require('./order.model');

const router = express.Router();

// Zod DTO for create order
const CreateOrderDto = z.object({
  items: z.array(z.object({
    productId: z.string().min(1),
    qty: z.number().int().positive()
  })).min(1)
});

// Helpers
async function priceSnapshot(items) {
  // Fetch products and build map
  const ids = items.map(i => i.productId);
  const productDocs = await Product.find({ _id: { $in: ids } });
  const map = new Map(productDocs.map(p => [p._id.toString(), p]));

  // Build line items with snapshot and compute subtotal
  let subtotal = 0;
  const lines = items.map(it => {
    const p = map.get(it.productId);
    if (!p) throw new Error(`Product not found: ${it.productId}`);
    const price = Number(p.price);
    subtotal += price * it.qty;
    return {
      productId: new mongoose.Types.ObjectId(it.productId),
      name: p.name,
      price,
      qty: it.qty
    };
  });
  return { lines, subtotal };
}

// Create order (authenticated users)
router.post('/', jwtMiddleware, async (req, res) => {
  try {
    const { items } = CreateOrderDto.parse(req.body);
    const { lines, subtotal } = await priceSnapshot(items);

    const order = await Order.create({
      userId: new mongoose.Types.ObjectId(req.user.id),
      items: lines,
      subtotal,
      status: 'pending'
    });

    res.status(201).json(order);
  } catch (err) {
    res.status(400).json({ error: err.message || 'Bad request' });
  }
});

// Get current user's orders
router.get('/my', jwtMiddleware, async (req, res) => {
  const orders = await Order.find({ userId: req.user.id }).sort({ createdAt: -1 });
  res.json(orders);
});

// Get one order (owner or admin)
router.get('/:id', jwtMiddleware, async (req, res) => {
  const order = await Order.findById(req.params.id);
  if (!order) return res.status(404).json({ error: 'Not found' });
  const isOwner = order.userId.toString() === req.user.id;
  const isAdmin = req.user.role === 'admin';
  if (!isOwner && !isAdmin) return res.status(403).json({ error: 'Forbidden' });
  res.json(order);
});

// Admin: list all orders
router.get('/', jwtMiddleware, roleGuard(['admin']), async (_req, res) => {
  const orders = await Order.find().sort({ createdAt: -1 });
  res.json(orders);
});

// Admin: update status
router.patch('/:id/status', jwtMiddleware, roleGuard(['admin']), async (req, res) => {
  const { status } = z.object({ status: z.enum(['pending', 'paid', 'cancelled']) }).parse(req.body);
  const order = await Order.findByIdAndUpdate(req.params.id, { status }, { new: true });
  if (!order) return res.status(404).json({ error: 'Not found' });
  res.json(order);
});

module.exports = router;
```

